{
  "manifest_version": 3,
  "name": "Popup Audio Phase Analyzer",
  "version": "0.1",
  "description": "Real-time peak meter and phase analyzer for browser audio",
  "permissions": ["tabCapture", "activeTab", "scripting", "offscreen"],
  "web_accessible_resources": [{
    "resources": ["popup.html", "popup.js"],
    "matches": ["<all_urls>"]
  }],
"action": {
  "default_title": "Popup Audio Phase Analyzer",
  "default_icon": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png"
  }
},
"icons": {
  "16": "icons/icon16.png",
  "32": "icons/icon32.png",
  "48": "icons/icon48.png",
  "128": "icons/icon128.png"
},
  "background": {
    "service_worker": "background.js"
  }
}
